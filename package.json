{
  "name": "ai-tracker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro check && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:sources": "tsx scripts/verify-sources.ts",
    "verify:refs": "tsx scripts/verify-refs.ts",
    "verify:all": "pnpm verify:refs && pnpm verify:sources",
    "ingest:dry": "tsx scripts/ingest.ts --dry-run",
    "ingest:staging": "tsx scripts/ingest.ts --write-staging",
    "ingest:apply": "tsx scripts/ingest.ts --apply",
    "ingest:apply:updates": "tsx scripts/ingest.ts --apply --updates-only",
    "ingest:queue": "tsx scripts/ingest-to-queue.ts",
    "ingest:queue:status": "tsx scripts/ingest-to-queue.ts --status"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@10.33.3"
}
