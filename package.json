{
  "name": "ai-tracker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro check && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:sources": "tsx scripts/verify-sources.ts",
    "verify:refs": "tsx scripts/verify-refs.ts",
    "verify:headers": "tsx scripts/verify-headers.ts",
    "verify:all": "pnpm verify:refs && pnpm verify:sources && pnpm verify:headers",
    "ingest:dry": "tsx scripts/ingest.ts --dry-run",
    "ingest:staging": "tsx scripts/ingest.ts --write-staging",
    "ingest:apply": "tsx scripts/ingest.ts --apply",
    "ingest:apply:updates": "tsx scripts/ingest.ts --apply --updates-only",
    "ingest:queue": "tsx scripts/ingest-to-queue.ts",
    "ingest:queue:status": "tsx scripts/ingest-to-queue.ts --status",
    "events:backfill-releases": "tsx scripts/generate-release-events.ts",
    "events:backfill-releases:dry": "tsx scripts/generate-release-events.ts --dry-run",
    "events:backfill-pricing": "tsx scripts/generate-pricing-events.ts",
    "events:backfill-pricing:dry": "tsx scripts/generate-pricing-events.ts --dry-run",
    "tools:fill-built-on": "tsx scripts/fill-built-on-models.ts",
    "tools:fill-built-on:dry": "tsx scripts/fill-built-on-models.ts --dry-run",
    "cache:sweep": "tsx scripts/png-cache-sweep.ts",
    "cache:sweep:dry": "tsx scripts/png-cache-sweep.ts --dry-run"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@10.33.3"
}
