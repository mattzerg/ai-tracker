---
import Base from "../../layouts/Base.astro";
import ProviderMark from "../../components/ProviderMark.astro";
import { loadModels, loadTools } from "../../lib/data.ts";

const models = loadModels().sort((a, b) => (b.released ?? "0").localeCompare(a.released ?? "0"));
const providers = Array.from(new Set(models.map((m) => m.provider))).sort();
const licenses = Array.from(new Set(models.map((m) => m.license))).sort();

const usageCount = new Map<string, number>();
for (const t of loadTools()) for (const id of t.built_on_models) usageCount.set(id, (usageCount.get(id) ?? 0) + 1);

const tagCounts = new Map<string, number>();
for (const m of models) for (const tag of m.tags) tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
const tags = Array.from(tagCounts.entries()).sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---
<Base title="Models — ai-tracker" description="All tracked AI models.">
  <h1>Models</h1>
  <p>{models.length} tracked.</p>

  <div class="filters">
    <label>
      Provider
      <select id="filter-provider">
        <option value="">all</option>
        {providers.map((p) => <option value={p}>{p}</option>)}
      </select>
    </label>
    <label>
      License
      <select id="filter-license">
        <option value="">all</option>
        {licenses.map((l) => <option value={l}>{l}</option>)}
      </select>
    </label>
    <label>
      Tag
      <select id="filter-tag">
        <option value="">all</option>
        {tags.map(([t, n]) => <option value={t}>{t} ({n})</option>)}
      </select>
    </label>
    <label>
      Sort
      <select id="sort">
        <option value="released-desc">Released ↓</option>
        <option value="released-asc">Released ↑</option>
        <option value="price-asc">Input price ↑</option>
        <option value="price-desc">Input price ↓</option>
        <option value="context-desc">Context ↓</option>
        <option value="tools-desc">Tools using ↓</option>
        <option value="name-asc">Name A→Z</option>
      </select>
    </label>
    <span id="visible-count" class="count">{models.length} visible</span>
  </div>

  <p id="empty-state" hidden><em>No models match those filters. <a href="#" id="clear-filters">Clear filters</a>.</em></p>

  <table class="models">
    <thead>
      <tr>
        <th class="cmp-col"></th>
        <th>Name</th>
        <th>Provider</th>
        <th>Released</th>
        <th>Context</th>
        <th>$/M in</th>
        <th>$/M out</th>
        <th>License</th>
        <th>Tools</th>
      </tr>
    </thead>
    <tbody id="models-body">
      {models.map((m) => {
        const tu = usageCount.get(m.id) ?? 0;
        return (
        <tr
          data-provider={m.provider}
          data-license={m.license}
          data-tags={m.tags.join(" ")}
          data-released={m.released ?? ""}
          data-input={m.pricing?.input_per_mtok ?? ""}
          data-context={m.context_window ?? ""}
          data-tools={tu}
          data-name={m.name}
          data-id={m.id}
        >
          <td class="cmp-col"><input type="checkbox" class="cmp" data-id={m.id} aria-label={`Compare ${m.name}`} /></td>
          <td><a href={`/models/${m.id}`}>{m.name}</a></td>
          <td><ProviderMark provider={m.provider} size={18} /><a href={`/providers/${m.provider}`}>{m.provider}</a></td>
          <td>{m.released ?? "—"}</td>
          <td class="num">{m.context_window ? m.context_window.toLocaleString() : "—"}</td>
          <td class="num">{m.pricing?.input_per_mtok ?? "—"}</td>
          <td class="num">{m.pricing?.output_per_mtok ?? "—"}</td>
          <td>{m.license}</td>
          <td class="num">{tu || "—"}</td>
        </tr>
      );})}
    </tbody>
  </table>

  <div id="cmp-bar" hidden>
    <span id="cmp-count">0</span> selected — max 6.
    <a id="cmp-link" href="#">Compare →</a>
    <button id="cmp-clear" type="button">Clear</button>
  </div>

  <style>
    .filters { display: flex; gap: 1rem; align-items: center; margin: 1rem 0; padding: 0.75rem; background: #f6f6f6; border-radius: 4px; flex-wrap: wrap; }
    .filters label { display: inline-flex; gap: 0.4rem; align-items: center; font-size: 0.9rem; }
    .filters select { padding: 0.25rem 0.4rem; }
    .count { margin-left: auto; color: #666; font-size: 0.85rem; }
    table.models { width: 100%; border-collapse: collapse; font-size: 0.92rem; }
    table.models th, table.models td { padding: 0.4rem 0.5rem; text-align: left; border-bottom: 1px solid #eee; }
    table.models th { background: #f9f9f9; font-weight: 600; }
    table.models td.num { text-align: right; font-variant-numeric: tabular-nums; }
    table.models th.cmp-col, table.models td.cmp-col { width: 1.5rem; padding: 0.4rem 0.3rem; }
    tr[hidden] { display: none; }
    #cmp-bar { position: fixed; bottom: 0; left: 0; right: 0; padding: 0.7rem 1rem; background: #111; color: #fff; display: flex; gap: 1rem; align-items: center; justify-content: center; box-shadow: 0 -2px 8px rgba(0,0,0,0.15); font-size: 0.95rem; }
    #cmp-bar a { color: #8eb6ff; font-weight: 600; }
    #cmp-bar button { background: transparent; color: #ccc; border: 1px solid #555; padding: 0.25rem 0.6rem; border-radius: 3px; cursor: pointer; }
    #cmp-bar button:hover { color: #fff; border-color: #888; }
  </style>
  <script is:inline>
    (() => {
      const provSel = document.getElementById("filter-provider");
      const licSel = document.getElementById("filter-license");
      const tagSel = document.getElementById("filter-tag");
      const sortSel = document.getElementById("sort");
      const tbody = document.getElementById("models-body");
      const counter = document.getElementById("visible-count");
      if (!provSel || !licSel || !tagSel || !sortSel || !tbody || !counter) return;
      const rows = Array.from(tbody.querySelectorAll("tr"));

      function num(v) { const n = parseFloat(v); return Number.isFinite(n) ? n : null; }

      function sortKey(row, mode) {
        if (mode === "name-asc") return row.dataset.name.toLowerCase();
        if (mode.startsWith("released")) return row.dataset.released || "";
        if (mode.startsWith("price")) return num(row.dataset.input);
        if (mode.startsWith("context")) return num(row.dataset.context);
        if (mode.startsWith("tools")) return num(row.dataset.tools);
        return "";
      }

      function compare(a, b, mode) {
        const desc = mode.endsWith("-desc");
        const ka = sortKey(a, mode);
        const kb = sortKey(b, mode);
        // nulls last
        if (ka == null && kb == null) return 0;
        if (ka == null) return 1;
        if (kb == null) return -1;
        if (typeof ka === "number" && typeof kb === "number") return desc ? kb - ka : ka - kb;
        return desc ? String(kb).localeCompare(String(ka)) : String(ka).localeCompare(String(kb));
      }

      const empty = document.getElementById("empty-state");
      const clearLink = document.getElementById("clear-filters");
      function apply() {
        const p = provSel.value;
        const l = licSel.value;
        const tag = tagSel.value;
        const mode = sortSel.value;
        const visible = rows.filter((r) => {
          if (p && r.dataset.provider !== p) return false;
          if (l && r.dataset.license !== l) return false;
          if (tag && !(r.dataset.tags || "").split(" ").includes(tag)) return false;
          return true;
        });
        for (const r of rows) r.hidden = !visible.includes(r);
        const sorted = visible.slice().sort((a, b) => compare(a, b, mode));
        for (const r of sorted) tbody.appendChild(r);
        counter.textContent = visible.length + " visible";
        if (empty) empty.hidden = visible.length > 0;
      }
      provSel.addEventListener("change", apply);
      licSel.addEventListener("change", apply);
      tagSel.addEventListener("change", apply);
      sortSel.addEventListener("change", apply);
      if (clearLink) clearLink.addEventListener("click", (e) => {
        e.preventDefault(); provSel.value = ""; licSel.value = ""; tagSel.value = ""; apply();
      });

      // Compare picker.
      const cmpBar = document.getElementById("cmp-bar");
      const cmpCount = document.getElementById("cmp-count");
      const cmpLink = document.getElementById("cmp-link");
      const cmpClear = document.getElementById("cmp-clear");
      const checkboxes = Array.from(document.querySelectorAll("input.cmp"));
      const MAX = 6;
      function selected() { return checkboxes.filter((c) => c.checked).map((c) => c.dataset.id); }
      function refreshBar() {
        const ids = selected();
        cmpCount.textContent = String(ids.length);
        cmpBar.hidden = ids.length === 0;
        cmpLink.href = "/compare?models=" + ids.join(",");
      }
      checkboxes.forEach((c) => c.addEventListener("change", () => {
        const ids = selected();
        if (ids.length > MAX) {
          c.checked = false;
          alert("Max " + MAX + " models. Uncheck one first.");
          return;
        }
        refreshBar();
      }));
      cmpClear.addEventListener("click", () => { checkboxes.forEach((c) => (c.checked = false)); refreshBar(); });
      refreshBar();
    })();
  </script>
</Base>
