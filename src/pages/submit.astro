---
import Base from "../layouts/Base.astro";
import { loadModels, loadRepos, loadTools } from "../lib/data.ts";

// Worker endpoint resolves at runtime via PUBLIC_API_BASE; if unset, the form
// degrades to "validate + copy JSON" + a GitHub-issue fallback. The page is fully
// useful before the submission Worker is deployed and seamlessly upgrades after.
const apiBase = import.meta.env.PUBLIC_API_BASE ?? "";
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITEKEY ?? "";
const ghIssuesUrl = import.meta.env.PUBLIC_GITHUB_ISSUES_URL ?? "";
const submitConfigGap = Boolean(apiBase && !turnstileSiteKey);

const entities = [
  ...loadModels().map((m) => ({ id: m.id, label: `${m.name} (model · ${m.provider})` })),
  ...loadTools().map((t) => ({ id: t.id, label: `${t.name} (tool · ${t.vendor})` })),
  ...loadRepos().map((r) => ({ id: r.id, label: `${r.full_name} (repo · ${r.category})` })),
].sort((a, b) => a.label.localeCompare(b.label));

const eventTypes = ["released", "price_change", "deprecated", "capability_added", "benchmark_update", "license_change", "model_swap", "shut_down", "rebrand", "acquired"];
const repoCategories = Array.from(new Set([...loadRepos().map((r) => r.category), "other"])).sort();
---
<Base
  title="Submit — ai-tracker"
  description="Submit a new model, tool, repo, or event for ai-tracker review."
>
  <h1>Submit</h1>
  <p>
    Add a model, tool, repo, or event. Submissions are reviewed before they land in
    the public catalog, and every accepted record needs an authoritative source URL.
  </p>
  {!apiBase ? (
    <p class="banner">
      <strong>Submissions are reviewed by hand right now.</strong> Fill in the form below —
      it validates your entry and builds the exact JSON a reviewer needs. Then send it
      {ghIssuesUrl ? " via the pre-filled GitHub issue" : " with the Copy JSON button"} (below).
      Every accepted record needs an authoritative source URL.
    </p>
  ) : null}
  {submitConfigGap ? (
    <p class="banner warning">
      <strong>Config gap.</strong> Live API is configured, but Turnstile site key is not.
      Use the GitHub issue or copy JSON path until the site key is set.
    </p>
  ) : null}

  <section class="submission-paths" aria-label="Submission paths">
    <div class:list={["path-card", apiBase && !submitConfigGap && "available"]}>
      <strong>Live API</strong>
      <span>{submitConfigGap ? "Missing Turnstile site key" : apiBase ? "Enabled for this build" : "Not configured yet"}</span>
    </div>
    <div class:list={["path-card", ghIssuesUrl && "available"]}>
      <strong>GitHub issue</strong>
      <span>{ghIssuesUrl ? "Fallback link will prefill the JSON" : "No issue URL configured"}</span>
    </div>
    <div class="path-card available">
      <strong>Copy JSON</strong>
      <span>Always available for manual review or PR comments</span>
    </div>
  </section>

  <form id="submit-form">
    <div class="row">
      <label for="kind">What kind of submission?</label>
      <select id="kind" name="kind" required>
        <option value="event">Event on an existing entity (price change, deprecation, etc.)</option>
        <option value="model">New model</option>
        <option value="tool">New tool</option>
        <option value="repo">New developer repo</option>
      </select>
    </div>

    <fieldset id="event-fields">
      <legend>Event</legend>
      <div class="row">
        <label for="entity">Entity</label>
        <input type="text" id="entity" name="entity" list="entity-list" placeholder="e.g. anthropic__claude-opus-4-7" />
        <datalist id="entity-list">
          {entities.map((e) => <option value={e.id}>{e.label}</option>)}
        </datalist>
      </div>
      <div class="row">
        <label for="type">Event type</label>
        <select id="type" name="type">
          {eventTypes.map((t) => <option value={t}>{t}</option>)}
        </select>
      </div>
      <div class="row">
        <label for="date">Date (ISO)</label>
        <input type="date" id="date" name="date" />
      </div>
      <div class="row">
        <label for="summary">Summary (max 280 chars)</label>
        <textarea id="summary" name="summary" rows="3" maxlength="280"></textarea>
      </div>
      <div class="row delta">
        <label>Delta (optional, for price/license/etc.)</label>
        <div class="delta-inputs">
          <input type="text" name="delta_field" placeholder="field path (e.g. pricing.input_per_mtok)" />
          <input type="text" name="delta_from" placeholder="from" />
          <input type="text" name="delta_to" placeholder="to" />
        </div>
      </div>
    </fieldset>

    <fieldset id="entity-fields" hidden>
      <legend>New entity</legend>
      <div class="row">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" maxlength="120" />
      </div>
      <div class="row">
        <label for="provider">Provider / vendor</label>
        <input type="text" id="provider" name="provider" />
      </div>
      <div class="row">
        <label for="released">Released (ISO date)</label>
        <input type="date" id="released" name="released" />
      </div>
      <div class="row">
        <label for="notes">Other details (pricing, context window, license, anything we should know)</label>
        <textarea id="notes" name="notes" rows="5" maxlength="1000"></textarea>
      </div>
    </fieldset>

    <fieldset id="repo-fields" hidden>
      <legend>New repo</legend>
      <div class="row">
        <label for="repo-full-name">GitHub repo</label>
        <input type="text" id="repo-full-name" name="repo_full_name" maxlength="160" placeholder="owner/name" />
      </div>
      <div class="row">
        <label for="repo-category">Category</label>
        <select id="repo-category" name="repo_category">
          {repoCategories.map((category) => <option value={category}>{category}</option>)}
        </select>
      </div>
      <div class="row">
        <label for="repo-url">Repo URL</label>
        <input type="url" id="repo-url" name="repo_url" placeholder="https://github.com/owner/name" />
      </div>
      <div class="row">
        <label for="repo-notes">Why this belongs in ai-tracker</label>
        <textarea id="repo-notes" name="repo_notes" rows="4" maxlength="1000"></textarea>
      </div>
    </fieldset>

    <div class="row">
      <label for="source">Source URL (must be authoritative — provider docs, official blog, etc.)</label>
      <input type="url" id="source" name="source" required placeholder="https://www.anthropic.com/news/..." />
    </div>

    <div class="row">
      <label for="contact">Your contact (optional, for follow-up only)</label>
      <input type="email" id="contact" name="contact" placeholder="you@example.com" />
    </div>

    {turnstileSiteKey ? (
      <div id="turnstile-slot" class="cf-turnstile" data-sitekey={turnstileSiteKey} data-callback="onTurnstileToken"></div>
    ) : (
      <div id="turnstile-slot" class="turnstile-stub"></div>
    )}
    <input type="hidden" id="turnstile-token" name="turnstile" value="" />

    <h3>Preview JSON</h3>
    <pre id="preview" class="preview">{`{}`}</pre>

    <div id="errors" class="errors" hidden></div>

    <div class="actions">
      <button type="submit" id="submit-btn" disabled>Submit</button>
      {ghIssuesUrl ? (
        <a id="gh-fallback" href={ghIssuesUrl} target="_blank" rel="noopener" class="secondary-link">Open GitHub issue</a>
      ) : null}
      <button type="button" id="copy-json-btn" class="secondary">Copy JSON</button>
    </div>

    <p id="result" class="result" hidden></p>
  </form>

  <style>
    form { display: flex; flex-direction: column; gap: 0; max-width: 100%; }
    .submission-paths { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 0.75rem; margin: 1rem 0 1.2rem; }
    .path-card { padding: 0.8rem; border: 1px solid var(--line); border-radius: 8px; background: var(--surface); color: var(--muted); }
    .path-card strong { display: block; color: var(--text); margin-bottom: 0.18rem; }
    .path-card span { font-size: 0.9rem; }
    .path-card.available { border-color: #bfe5dd; background: var(--accent-soft); color: var(--accent-strong); }
    .banner.warning { border-left-color: #b7791f; background: #fff8e5; color: #70520b; }
    fieldset { margin: 1rem 0; padding: 0.8rem 1rem; border: 1px solid var(--line); border-radius: 8px; background: var(--surface); }
    fieldset legend { font-weight: 700; padding: 0 0.4rem; color: var(--text); }
    .row { display: flex; flex-direction: column; gap: 0.3rem; margin-bottom: 0.8rem; }
    .row label { font-size: 0.9rem; font-weight: 650; color: #394457; }
    input[type="text"], input[type="url"], input[type="email"], input[type="date"], select, textarea {
      padding: 0.45rem 0.6rem; border: 1px solid var(--line); border-radius: 6px; font: inherit; font-size: 0.95rem; background: #fff;
    }
    textarea { font-family: inherit; }
    .delta-inputs { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 0.4rem; }
    .preview { background: #0e1116; color: #d4d8e0; padding: 0.8rem 1rem; border-radius: 8px; font-size: 0.85rem; overflow-x: auto; }
    .banner { background: #fff8e0; padding: 0.6rem 0.8rem; border-left: 3px solid #d4a02a; border-radius: 6px; }
    .turnstile-stub { background: #f6f6f6; padding: 0.6rem; border: 1px dashed #ccc; border-radius: 3px; font-size: 0.8rem; color: #666; text-align: center; }
    .turnstile-stub::before { content: "Spam check appears here once live submission is enabled."; }
    .errors { background: #fff0f0; border-left: 3px solid #c33; padding: 0.5rem 0.8rem; border-radius: 3px; font-size: 0.88rem; margin-top: 0.5rem; }
    .errors ul { margin: 0; padding-left: 1.2rem; }
    .actions { display: flex; gap: 0.8rem; align-items: center; margin-top: 1rem; flex-wrap: wrap; }
    button { padding: 0.5rem 1.2rem; font: inherit; cursor: pointer; background: var(--text); color: #fff; border: none; border-radius: 7px; font-weight: 700; }
    button.secondary { background: #fff; color: #18202f; border: 1px solid #ccc; }
    button:disabled { background: #999; cursor: not-allowed; }
    .secondary-link { display: inline-flex; align-items: center; min-height: 40px; padding: 0.5rem 0.8rem; border-radius: 7px; border: 1px solid var(--line); background: var(--surface); color: var(--text); text-decoration: none; font-weight: 700; }
    .result { margin-top: 1rem; padding: 0.6rem 0.8rem; border-radius: 3px; }
    .result.ok { background: #f0fff4; border-left: 3px solid #2a8a4f; }
    .result.err { background: #fff0f0; border-left: 3px solid #c33; }
    @media (max-width: 760px) {
      .submission-paths { grid-template-columns: 1fr; }
      .delta-inputs { grid-template-columns: 1fr; }
    }
  </style>

  {turnstileSiteKey ? (
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  ) : null}
  <script is:inline define:vars={{ apiBase, ghIssuesUrl, turnstileSiteKey }}>
    (() => {
      const form = document.getElementById("submit-form");
      const kind = document.getElementById("kind");
      const eventFields = document.getElementById("event-fields");
      const entityFields = document.getElementById("entity-fields");
      const repoFields = document.getElementById("repo-fields");
      const preview = document.getElementById("preview");
      const result = document.getElementById("result");
      const submitBtn = document.getElementById("submit-btn");
      const ghFallback = document.getElementById("gh-fallback");
      const copyJsonBtn = document.getElementById("copy-json-btn");
      const errBox = document.getElementById("errors");

      window.onTurnstileToken = (token) => {
        const el = document.getElementById("turnstile-token");
        if (el) {
          el.value = token;
          refresh();
        }
      };

      // Mirror of the Zod rules from schemas/event.ts and schemas/common.ts.
      // Keep in sync if either changes.
      const ENTITY_ID_RX = /^[a-z0-9][a-z0-9_-]*(?:__[a-z0-9][a-z0-9._-]*)?$/;
      const ISO_DATE_RX = /^\d{4}-\d{2}-\d{2}$/;
      const URL_RX = /^https?:\/\/\S+$/;
      const EVENT_TYPES = new Set(["released","price_change","deprecated","capability_added","benchmark_update","license_change","model_swap","shut_down","rebrand","acquired"]);

      function validate(payload) {
        const errs = [];
        if (!payload.source) errs.push("Source URL is required.");
        else if (!URL_RX.test(payload.source)) errs.push("Source must be a valid http(s) URL.");
        if (payload.contact && !/^\S+@\S+\.\S+$/.test(payload.contact)) errs.push("Contact must be a valid email.");
        if (apiBase && !turnstileSiteKey) errs.push("Live submission needs a Turnstile site key. Use GitHub issue or Copy JSON instead.");
        if (turnstileSiteKey && apiBase && !payload.turnstile) errs.push("Solve the Turnstile challenge before submitting.");
        if (payload.kind === "event") {
          const ev = payload.event;
          if (!ev.entity) errs.push("Entity is required (use the autocomplete).");
          else if (!ENTITY_ID_RX.test(ev.entity)) errs.push("Entity must look like an existing id (e.g. anthropic__claude-opus-4-7).");
          if (!ev.type || !EVENT_TYPES.has(ev.type)) errs.push("Event type must be one of: " + Array.from(EVENT_TYPES).join(", ") + ".");
          if (!ev.date) errs.push("Date is required.");
          else if (!ISO_DATE_RX.test(ev.date)) errs.push("Date must be ISO YYYY-MM-DD.");
          if (!ev.summary) errs.push("Summary is required.");
          else if (ev.summary.length > 280) errs.push("Summary must be 280 chars or fewer.");
          if (ev.delta?.field && (ev.delta.from == null || ev.delta.to == null)) {
            errs.push("Delta requires from and to values.");
          }
        } else if (payload.kind === "repo") {
          const ent = payload.entity;
          if (!ent.full_name) errs.push("GitHub repo is required.");
          else if (!/^[^/\s]+\/[^/\s]+$/.test(ent.full_name)) errs.push("GitHub repo must look like owner/name.");
          if (!ent.repo_url) errs.push("Repo URL is required.");
          else if (!URL_RX.test(ent.repo_url)) errs.push("Repo URL must be a valid http(s) URL.");
          if (!ent.category) errs.push("Category is required.");
        } else {
          const ent = payload.entity;
          if (!ent.name) errs.push("Name is required.");
          if (!ent.provider) errs.push((payload.kind === "tool" ? "Vendor" : "Provider") + " is required.");
          if (ent.released && !ISO_DATE_RX.test(ent.released)) errs.push("Released must be ISO YYYY-MM-DD or empty.");
        }
        return errs;
      }

      function val(id) { const el = document.getElementById(id); return el ? el.value.trim() : ""; }
      function pickByName(name) { const el = form.querySelector(`[name="${name}"]`); return el ? el.value.trim() : ""; }

      function renderErrors(errs) {
        errBox.replaceChildren();
        const title = document.createElement("strong");
        title.textContent = "Fix these before submitting:";
        const list = document.createElement("ul");
        for (const message of errs) {
          const item = document.createElement("li");
          item.textContent = message;
          list.appendChild(item);
        }
        errBox.append(title, list);
      }

      function buildPayload() {
        const k = kind.value;
        const source = val("source");
        const contact = val("contact");
        const turnstile = val("turnstile-token") || undefined;
        const base = { kind: k, source, contact: contact || undefined, turnstile };
        if (k === "event") {
          const delta_field = pickByName("delta_field");
          const delta_from = pickByName("delta_from");
          const delta_to = pickByName("delta_to");
          const event = {
            entity: val("entity"),
            type: val("type"),
            date: val("date"),
            summary: val("summary"),
            ...(delta_field ? { delta: { field: delta_field, from: delta_from || null, to: delta_to || null } } : {}),
          };
          return { ...base, event };
        }
        if (k === "repo") {
          return {
            ...base,
            entity: {
              kind: "repo",
              full_name: pickByName("repo_full_name"),
              category: pickByName("repo_category"),
              repo_url: pickByName("repo_url"),
              notes: pickByName("repo_notes"),
            },
          };
        }
        return {
          ...base,
          entity: {
            kind: k,
            name: val("name"),
            provider: val("provider"),
            released: val("released") || null,
            notes: pickByName("notes"),
          },
        };
      }

      function refresh() {
        const k = kind.value;
        eventFields.hidden = k !== "event";
        entityFields.hidden = k === "event" || k === "repo";
        repoFields.hidden = k !== "repo";
        const p = buildPayload();
        preview.textContent = JSON.stringify(p, null, 2);
        // Wire the GitHub fallback to pre-fill an issue with the JSON payload.
        if (ghFallback && ghIssuesUrl) {
          const issueUrl = new URL(ghIssuesUrl);
          issueUrl.searchParams.set("title", `[submit] ${k}: ${val("summary") || val("name") || pickByName("repo_full_name") || "untitled"}`);
          issueUrl.searchParams.set("body", "```json\n" + JSON.stringify(p, null, 2) + "\n```");
          const href = issueUrl.toString();
          if (href.length > 7000) {
            ghFallback.removeAttribute("href");
            ghFallback.textContent = "GitHub issue too large — copy JSON";
          } else {
            ghFallback.href = href;
            ghFallback.textContent = "Open GitHub issue";
          }
        }
        // Validation gate.
        const errs = validate(p);
        if (errs.length === 0) {
          errBox.hidden = true;
          submitBtn.disabled = !apiBase || (apiBase && !turnstileSiteKey);
          submitBtn.textContent = apiBase && turnstileSiteKey
            ? "Submit"
            : (ghIssuesUrl ? "Use GitHub issue →" : "Copy JSON to submit →");
        } else {
          errBox.hidden = false;
          renderErrors(errs);
          submitBtn.disabled = true;
          submitBtn.textContent = "Submit (fix errors)";
        }
      }

      form.addEventListener("input", refresh);
      kind.addEventListener("change", refresh);
      refresh();

      if (copyJsonBtn) {
        copyJsonBtn.addEventListener("click", async () => {
          try {
            await navigator.clipboard.writeText(preview.textContent || "{}");
            result.hidden = false;
            result.className = "result ok";
            result.textContent = "Submission JSON copied.";
          } catch {
            result.hidden = false;
            result.className = "result err";
            result.textContent = "Copy failed. Select the preview JSON manually.";
          }
        });
      }

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (!apiBase) {
          result.hidden = false;
          result.className = "result err";
          result.textContent = ghIssuesUrl
            ? "Live submission isn't enabled yet — use the GitHub issue link instead."
            : "Live submission isn't enabled yet — copy the JSON for manual review.";
          return;
        }
        submitBtn.disabled = true;
        result.hidden = false;
        result.className = "result";
        result.textContent = "Submitting…";
        try {
          const res = await fetch(`${apiBase}/submit`, {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify(buildPayload()),
          });
          const body = await res.json().catch(() => ({}));
          if (res.ok) {
            result.className = "result ok";
            result.textContent = body.message || "Submitted. Watch the queue PR for review.";
          } else {
            result.className = "result err";
            result.textContent = body.error || `Failed (${res.status}).`;
          }
        } catch (err) {
          result.className = "result err";
          result.textContent = "Network error: " + err.message;
        } finally {
          submitBtn.disabled = false;
        }
      });
    })();
  </script>
</Base>
