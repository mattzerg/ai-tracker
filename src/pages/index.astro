---
import Base from "../layouts/Base.astro";
import { entityById, loadEvents, loadModels, loadRepos, loadTools } from "../lib/data.ts";
import { catalogFreshness } from "../lib/freshness.ts";

const allEvents = loadEvents();
const events = allEvents.slice(0, 12);
const models = loadModels();
const tools = loadTools();
const repos = loadRepos();
const providerCount = new Set(models.map((m) => m.provider)).size;
const categoryCount = new Set(tools.map((t) => t.category)).size;
const repoCategoryCount = new Set(repos.map((r) => r.category)).size;
const freshness = catalogFreshness(allEvents, models, repos);

// Highlights — actually useful comparisons.
const cheapestInput = models
  .filter((m) => m.pricing?.input_per_mtok != null)
  .sort((a, b) => (a.pricing!.input_per_mtok! - b.pricing!.input_per_mtok!))
  .slice(0, 3);
const longestContext = models
  .filter((m) => m.context_window != null)
  .sort((a, b) => (b.context_window! - a.context_window!))
  .slice(0, 3);
const usageCount = new Map<string, number>();
for (const t of tools) for (const id of t.built_on_models) usageCount.set(id, (usageCount.get(id) ?? 0) + 1);
const mostUsed = Array.from(usageCount.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5)
  .map(([id, count]) => ({ model: models.find((m) => m.id === id)!, count }))
  .filter((x) => x.model);

function entityPath(id: string): string {
  const e = entityById(id);
  if (!e) {
    console.warn(`event references unknown entity: ${id}`);
    return `#${id}`;
  }
  if (e.kind === "model") return `/models/${id}`;
  if (e.kind === "tool") return `/tools/${id}`;
  return `/repos/${id}`;
}

function eventTypeLabel(type: string): string {
  return type.replaceAll("_", " ");
}
---
<Base title="ai-tracker — AI models, tools, repos, and changes" description="Source-backed directory and machine-readable changelog of AI models, tools, developer repos, and market changes.">
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Machine-readable AI market tracker</p>
      <h1>AI models, tools, repos, and changes.</h1>
      <p class="lede">
        A public directory, changelog, and agent-facing data feed for model releases, pricing shifts,
        tool ecosystems, open-source repos, and source-backed metadata for agents and humans.
      </p>
      <p class="trust-strip">Public beta · source-backed records · free · no signup · open data · <a href="/about">how this is run</a></p>
      <div class="button-row">
        <a href="/changes" class="button primary">See changes</a>
        <a href="/models" class="button">Browse models</a>
        <a href="/tools" class="button">Browse tools</a>
        <a href="/repos" class="button">Track repos</a>
        <a href="/llms.txt" class="button">For agents</a>
      </div>
    </div>
    <div class="hero-panel panel" aria-label="Tracker coverage">
      <div class="stat-grid">
        <a href="/models" class="stat">
          <strong>{models.length}</strong>
          <span>models</span>
        </a>
        <a href="/tools" class="stat">
          <strong>{tools.length}</strong>
          <span>tools</span>
        </a>
        <a href="/repos" class="stat">
          <strong>{repos.length}</strong>
          <span>repos</span>
        </a>
        <a href="/changes" class="stat">
          <strong>{allEvents.length}</strong>
          <span>events</span>
        </a>
      </div>
      <div class="surface-links">
        <span>{providerCount} model providers, {categoryCount} tool categories, {repoCategoryCount} repo categories</span>
        <span>{freshness.label} from {freshness.source}</span>
        <a href="/providers">providers</a>
        <a href="/categories">categories</a>
        <a href="/api/search.json">search.json</a>
        <a href="/dump/all.json">all.json</a>
        <a href="/sitemap-agents.xml">sitemap</a>
      </div>
    </div>
  </section>

  <section class="section-head">
    <div>
      <p class="eyebrow">Ranked snapshots</p>
      <h2>Useful cuts through the catalog</h2>
      <p class="section-note">These are sortable metadata views from tracked pricing, context windows, and tool links. They are not benchmark rankings.</p>
    </div>
    <a href="/compare">Compare models</a>
  </section>

  <section class="highlights" aria-label="Model highlights">
    <div class="insight-card">
      <h3>Cheapest input</h3>
      <ol>
        {cheapestInput.map((m) => (
          <li>
            <a href={`/models/${m.id}`}>{m.name}</a>
            <span>${m.pricing!.input_per_mtok}/M</span>
          </li>
        ))}
      </ol>
    </div>
    <div class="insight-card">
      <h3>Longest context</h3>
      <ol>
        {longestContext.map((m) => (
          <li>
            <a href={`/models/${m.id}`}>{m.name}</a>
            <span>{m.context_window!.toLocaleString()} tok</span>
          </li>
        ))}
      </ol>
    </div>
    <div class="insight-card">
      <h3>Most used by tools</h3>
      <ol>
        {mostUsed.map((x) => (
          <li>
            <a href={`/models/${x.model.id}`}>{x.model.name}</a>
            <span>{x.count} tools</span>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="latest-section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Changelog</p>
        <h2>Latest tracked events</h2>
      </div>
      <a href="/changes">Changes by week</a>
    </div>
  {events.length === 0 ? (
    <p><em>No events yet - repo just bootstrapped.</em></p>
  ) : (
    <ol class="event-list">
      {events.map((e) => {
        const entity = entityById(e.entity);
        return (
          <li class="event-row">
            <time datetime={e.date}>{e.date}</time>
            <div>
              <span class="event-type">{eventTypeLabel(e.type)}</span>
              <a href={entityPath(e.entity)}>{entity?.name ?? e.entity}</a>
              <p>{e.summary}</p>
            </div>
          </li>
        );
      })}
    </ol>
  )}
  </section>

  <style>
    .hero { display: grid; grid-template-columns: minmax(0, 1.25fr) minmax(320px, 0.75fr); gap: 2rem; align-items: stretch; padding: 3.25rem 0 2rem; }
    .hero-copy { min-width: 0; }
    .hero h1 { max-width: 880px; font-size: clamp(2.7rem, 7vw, 5.8rem); }
    .lede { max-width: 720px; margin: 1.1rem 0 0.85rem; font-size: clamp(1.05rem, 2vw, 1.28rem); color: #4f5a6d; }
    .trust-strip { max-width: 720px; margin: 0 0 1.45rem; font-size: 0.92rem; color: var(--muted); }
    .trust-strip a { color: inherit; text-decoration: underline; text-decoration-color: rgba(0,0,0,0.2); }
    .trust-strip a:hover { text-decoration-color: currentColor; }
    .hero-panel { padding: 1.15rem; align-self: end; }
    .stat-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.75rem; }
    .stat { min-height: 112px; display: flex; flex-direction: column; justify-content: flex-end; padding: 0.95rem; border: 1px solid var(--line); border-radius: 7px; background: linear-gradient(180deg, #ffffff, #f7f9fc); color: inherit; text-decoration: none; }
    .stat:hover { border-color: #b9c3d1; }
    .stat strong { color: var(--text); font-size: clamp(2rem, 5vw, 3.1rem); line-height: 0.95; font-variant-numeric: tabular-nums; }
    .stat span { margin-top: 0.45rem; color: var(--muted); font-size: 0.9rem; font-weight: 650; text-transform: uppercase; letter-spacing: 0.04em; }
    .surface-links { margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--line); display: flex; flex-wrap: wrap; gap: 0.55rem; align-items: center; font-size: 0.88rem; }
    .surface-links span { width: 100%; color: var(--muted); font-weight: 700; }
    .surface-links a { padding: 0.22rem 0.48rem; border-radius: 999px; background: var(--surface-soft); color: var(--text); text-decoration: none; }
    .section-head { display: flex; justify-content: space-between; align-items: end; gap: 1rem; margin: 2.5rem 0 1rem; }
    .section-head .eyebrow { margin-bottom: 0.35rem; }
    .section-note { max-width: 620px; margin: 0.35rem 0 0; }
    .section-head a { font-weight: 700; white-space: nowrap; }
    .highlights { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem; }
    .insight-card { padding: 1.05rem; background: var(--surface); border: 1px solid var(--line); border-radius: 8px; box-shadow: 0 10px 28px rgba(24, 32, 47, 0.05); }
    .insight-card h3 { margin: 0 0 0.8rem; font-size: 0.96rem; color: #394457; }
    .insight-card ol { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.55rem; }
    .insight-card li { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 0.8rem; align-items: baseline; padding-top: 0.55rem; border-top: 1px solid #edf0f5; }
    .insight-card li:first-child { border-top: 0; padding-top: 0; }
    .insight-card span { color: var(--muted); font-size: 0.88rem; font-variant-numeric: tabular-nums; white-space: nowrap; }
    .latest-section { margin-top: 0.5rem; }
    .event-list { list-style: none; padding: 0; margin: 0; background: var(--surface); border: 1px solid var(--line); border-radius: 8px; overflow: hidden; }
    .event-row { display: grid; grid-template-columns: 112px minmax(0, 1fr); gap: 1rem; padding: 0.9rem 1rem; border-top: 1px solid #edf0f5; }
    .event-row:first-child { border-top: 0; }
    .event-row time { color: var(--muted); font-size: 0.88rem; font-variant-numeric: tabular-nums; padding-top: 0.12rem; }
    .event-row a { font-weight: 750; color: var(--text); text-decoration: none; }
    .event-row a:hover { color: var(--blue); }
    .event-row p { margin: 0.28rem 0 0; color: #4f5a6d; }
    .event-type { display: inline-flex; margin-right: 0.5rem; padding: 0.12rem 0.42rem; border-radius: 999px; background: var(--accent-soft); color: var(--accent-strong); font-size: 0.75rem; font-weight: 750; text-transform: uppercase; letter-spacing: 0.04em; }
    @media (max-width: 900px) {
      .hero { grid-template-columns: 1fr; padding-top: 2rem; }
      .hero-panel { align-self: stretch; }
      .highlights { grid-template-columns: 1fr; }
    }
    @media (max-width: 620px) {
      .hero h1 { font-size: clamp(2.25rem, 14vw, 3.5rem); }
      .stat-grid { grid-template-columns: 1fr 1fr; }
      .stat { min-height: 92px; padding: 0.75rem; }
      .section-head { align-items: flex-start; flex-direction: column; }
      .event-row { grid-template-columns: 1fr; gap: 0.35rem; }
      .event-row time { padding-top: 0; }
    }
  </style>
</Base>
