---
import Base from "../../layouts/Base.astro";
import { loadRepoCandidateQueue } from "../../lib/data.ts";

const queue = loadRepoCandidateQueue();
const candidates = queue.candidates;
const categories = Array.from(new Set(candidates.map((r) => r.category))).sort();
const languages = Array.from(new Set(candidates.map((r) => r.language).filter((x): x is string => Boolean(x)))).sort();
const licenses = Array.from(new Set(candidates.map((r) => r.license).filter((x): x is string => Boolean(x)))).sort();
const topicCounts = new Map<string, number>();
for (const r of candidates) for (const t of new Set([...r.topics, ...r.tags])) topicCounts.set(t, (topicCounts.get(t) ?? 0) + 1);
const topics = Array.from(topicCounts.entries()).sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
const highSignal = candidates.filter((r) => (r.stars ?? 0) >= 10_000).length;
const currentYear = new Date().getFullYear();
const currentYearStart = `${currentYear}-01-01`;
const recentPushes = candidates.filter((r) => r.pushed_at && r.pushed_at >= currentYearStart).length;
const generatedLabel = queue.source === "none" ? "No candidate queue generated yet." : `Generated from ${queue.source} at ${queue.generated_at.slice(0, 10)}.`;

function compactNumber(n: number | null): string {
  if (n == null) return "n/a";
  return Intl.NumberFormat("en", { notation: "compact", maximumFractionDigits: 1 }).format(n);
}

function candidateJson(r: (typeof candidates)[number]): string {
  return JSON.stringify(r);
}
---
<Base title="Repo candidates — ai-tracker" description="GitHub-discovered AI repo candidates awaiting human review before promotion into the tracked catalog.">
  <section class="candidate-hero">
    <div>
      <p class="eyebrow">Review queue</p>
      <h1>Repo candidates</h1>
      <p class="lede">
        GitHub-discovered AI repositories that match tracked topics but still need human review before they become canonical ai-tracker entries.
      </p>
    </div>
    <div class="candidate-summary panel">
      <dl>
        <div><dt>Candidates</dt><dd>{candidates.length}</dd></div>
        <div><dt>10K+ stars</dt><dd>{highSignal}</dd></div>
        <div><dt>Languages</dt><dd>{languages.length}</dd></div>
        <div><dt>Known {currentYear} pushes</dt><dd>{recentPushes}</dd></div>
      </dl>
      <p>{generatedLabel}</p>
      <div class="summary-links">
        <a href="/repos">Tracked repos</a>
        <a href="/repos/candidates.json">JSON</a>
      </div>
    </div>
  </section>

  <div class="filters">
    <label class="search-label">
      Search
      <input type="search" id="filter-query" placeholder="claude, mcp, browser, vector..." />
    </label>
    <label>
      Category
      <select id="filter-category">
        <option value="">all</option>
        {categories.map((c) => <option value={c}>{c}</option>)}
      </select>
    </label>
    <label>
      Language
      <select id="filter-language">
        <option value="">all</option>
        {languages.map((l) => <option value={l}>{l}</option>)}
      </select>
    </label>
    <label>
      License
      <select id="filter-license">
        <option value="">all</option>
        {licenses.map((l) => <option value={l}>{l}</option>)}
      </select>
    </label>
    <label>
      Topic
      <select id="filter-topic">
        <option value="">all</option>
        {topics.map(([t, n]) => <option value={t}>{t} ({n})</option>)}
      </select>
    </label>
    <label>
      Minimum stars
      <select id="filter-stars">
        <option value="0">any</option>
        <option value="1000">1K+</option>
        <option value="10000">10K+</option>
        <option value="50000">50K+</option>
      </select>
    </label>
    <label>
      Sort
      <select id="sort-mode">
        <option value="stars-desc">stars</option>
        <option value="pushed-desc">recent push</option>
        <option value="name-asc">name</option>
      </select>
    </label>
    <span id="visible-count" class="count">{candidates.length} visible</span>
  </div>

  <p id="empty-state" hidden><em>No candidates match those filters. <a href="#" id="clear-filters">Clear filters</a>.</em></p>

  <div id="candidate-grid" class="candidate-grid">
    {candidates.map((r) => (
      <article
        class="candidate-card"
        data-category={r.category}
        data-language={r.language ?? ""}
        data-license={r.license ?? ""}
        data-name={r.full_name.toLowerCase()}
        data-description={(r.description ?? "").toLowerCase()}
        data-stars={r.stars ?? -1}
        data-pushed={r.pushed_at ?? ""}
        data-topics={JSON.stringify(Array.from(new Set([...r.topics, ...r.tags])))}
      >
        <div class="card-head">
          <a href={r.repo_url} rel="nofollow noopener" class="repo-name">{r.full_name}</a>
          <span>{r.category}</span>
        </div>
        <p>{r.description ?? "No description discovered."}</p>
        <dl>
          <div><dt>Stars</dt><dd>{compactNumber(r.stars)}</dd></div>
          <div><dt>Language</dt><dd>{r.language || "n/a"}</dd></div>
          <div><dt>License</dt><dd>{r.license || "n/a"}</dd></div>
          <div><dt>Pushed</dt><dd>{r.pushed_at ?? "n/a"}</dd></div>
        </dl>
        <div class="topic-row">
          {Array.from(new Set([...r.topics, ...r.tags])).slice(0, 7).map((t) => <span>{t}</span>)}
        </div>
        <div class="card-links">
          <a href={r.repo_url} rel="nofollow noopener">GitHub</a>
          {r.homepage ? <a href={r.homepage} rel="nofollow noopener">Homepage</a> : null}
          <button type="button" data-copy={`git clone ${r.repo_url}`}>Clone</button>
          <button type="button" data-copy={candidateJson(r)}>Copy JSON</button>
        </div>
      </article>
    ))}
  </div>

  <style>
    .candidate-hero { display: grid; grid-template-columns: minmax(0, 1fr) 300px; gap: 1.5rem; align-items: end; padding: 2.2rem 0 1rem; }
    .lede { max-width: 760px; font-size: 1.08rem; }
    .candidate-summary { padding: 1rem; display: grid; gap: 0.85rem; }
    .candidate-summary dl { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.75rem; margin: 0; }
    .candidate-summary dt { color: var(--muted); font-weight: 750; text-transform: uppercase; font-size: 0.72rem; letter-spacing: 0.04em; }
    .candidate-summary dd { margin: 0.1rem 0 0; color: var(--text); font-size: 1.8rem; line-height: 1; font-weight: 800; font-variant-numeric: tabular-nums; }
    .candidate-summary p { margin: 0; font-size: 0.86rem; }
    .summary-links { display: flex; flex-wrap: wrap; gap: 0.55rem; }
    .filters { display: flex; gap: 0.8rem; align-items: center; margin: 1rem 0 1.25rem; padding: 0.75rem; background: var(--surface); border: 1px solid var(--line); border-radius: 8px; flex-wrap: wrap; }
    .filters label { display: inline-flex; gap: 0.4rem; align-items: center; font-size: 0.9rem; color: #394457; font-weight: 650; }
    .filters select, .filters input[type="search"] { max-width: 190px; padding: 0.32rem 0.45rem; border: 1px solid var(--line); border-radius: 6px; background: #fff; font: inherit; }
    .filters .search-label { flex: 1 1 260px; }
    .filters .search-label input { width: 100%; max-width: none; }
    .count { margin-left: auto; color: var(--muted); font-size: 0.85rem; }
    .candidate-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }
    .candidate-card { display: grid; gap: 0.8rem; padding: 1rem; background: var(--surface); border: 1px solid var(--line); border-radius: 8px; box-shadow: 0 10px 28px rgba(24, 32, 47, 0.05); }
    .candidate-card[hidden] { display: none; }
    .card-head { display: flex; gap: 0.75rem; justify-content: space-between; align-items: baseline; }
    .repo-name { min-width: 0; overflow-wrap: anywhere; color: var(--text); font-weight: 800; text-decoration: none; }
    .card-head span { flex: 0 0 auto; padding: 0.16rem 0.45rem; border-radius: 999px; background: var(--accent-soft); color: var(--accent-strong); font-size: 0.75rem; font-weight: 750; }
    .candidate-card p { margin: 0; min-height: 3em; }
    .candidate-card dl { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 0.55rem; margin: 0; }
    .candidate-card dl div { padding-top: 0.55rem; border-top: 1px solid #edf0f5; min-width: 0; }
    .candidate-card dt { color: var(--muted); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.04em; font-weight: 750; }
    .candidate-card dd { margin: 0.18rem 0 0; color: var(--text); font-size: 0.92rem; overflow-wrap: anywhere; }
    .topic-row { display: flex; flex-wrap: wrap; gap: 0.38rem; min-height: 1.55rem; }
    .topic-row span { padding: 0.14rem 0.42rem; border-radius: 999px; background: #eef3fb; color: #34435a; font-size: 0.74rem; font-weight: 750; }
    .card-links { display: flex; flex-wrap: wrap; gap: 0.55rem; }
    .card-links a, .card-links button { padding: 0.22rem 0.48rem; border-radius: 999px; border: 0; background: var(--surface-soft); color: var(--text); text-decoration: none; font: inherit; font-size: 0.85rem; font-weight: 650; cursor: pointer; }
    .card-links button.copied { background: var(--accent-soft); color: var(--accent-strong); }
    @media (max-width: 800px) {
      .candidate-hero { grid-template-columns: 1fr; }
      .candidate-grid { grid-template-columns: 1fr; }
      .count { width: 100%; margin-left: 0; }
    }
    @media (max-width: 560px) {
      .candidate-card dl { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
  </style>
  <script is:inline>
    (() => {
      const cSel = document.getElementById("filter-category");
      const lSel = document.getElementById("filter-language");
      const licSel = document.getElementById("filter-license");
      const topicSel = document.getElementById("filter-topic");
      const starSel = document.getElementById("filter-stars");
      const qInp = document.getElementById("filter-query");
      const sortMode = document.getElementById("sort-mode");
      const grid = document.getElementById("candidate-grid");
      const counter = document.getElementById("visible-count");
      if (!cSel || !lSel || !licSel || !topicSel || !starSel || !qInp || !sortMode || !grid || !counter) return;
      const cards = Array.from(grid.querySelectorAll(".candidate-card"));
      const empty = document.getElementById("empty-state");
      const clearLink = document.getElementById("clear-filters");
      function dataList(value) {
        try {
          const parsed = JSON.parse(value || "[]");
          return Array.isArray(parsed) ? parsed : [];
        } catch {
          return [];
        }
      }
      function apply() {
        const c = cSel.value;
        const lang = lSel.value;
        const license = licSel.value;
        const topic = topicSel.value;
        const minStars = Number(starSel.value || 0);
        const query = qInp.value.trim().toLowerCase();
        let n = 0;
        for (const card of cards) {
          const topics = dataList(card.dataset.topics);
          const hay = [card.dataset.name, card.dataset.description, card.dataset.category, card.dataset.language, card.dataset.license, card.dataset.topics].join(" ").toLowerCase();
          const visible =
            (!query || hay.includes(query)) &&
            (!c || card.dataset.category === c) &&
            (!lang || card.dataset.language === lang) &&
            (!license || card.dataset.license === license) &&
            (!topic || topics.includes(topic)) &&
            (minStars === 0 || Number(card.dataset.stars) >= minStars);
          card.hidden = !visible;
          if (visible) n++;
        }
        const sorted = cards.slice().sort((a, b) => {
          if (sortMode.value === "pushed-desc") return (b.dataset.pushed || "").localeCompare(a.dataset.pushed || "") || a.dataset.name.localeCompare(b.dataset.name);
          if (sortMode.value === "name-asc") return a.dataset.name.localeCompare(b.dataset.name);
          return Number(b.dataset.stars) - Number(a.dataset.stars) || a.dataset.name.localeCompare(b.dataset.name);
        });
        for (const card of sorted) grid.appendChild(card);
        counter.textContent = n + " visible";
        if (empty) empty.hidden = n > 0;
      }
      for (const el of [cSel, lSel, licSel, topicSel, starSel, sortMode]) el.addEventListener("change", apply);
      qInp.addEventListener("input", apply);
      if (clearLink) clearLink.addEventListener("click", (e) => {
        e.preventDefault();
        cSel.value = ""; lSel.value = ""; licSel.value = ""; topicSel.value = ""; starSel.value = "0"; qInp.value = ""; sortMode.value = "stars-desc"; apply();
      });
      grid.addEventListener("click", async (e) => {
        const btn = e.target.closest("button[data-copy]");
        if (!btn) return;
        try {
          await navigator.clipboard.writeText(btn.dataset.copy);
          const old = btn.textContent;
          btn.textContent = "Copied";
          btn.classList.add("copied");
          setTimeout(() => { btn.textContent = old; btn.classList.remove("copied"); }, 1200);
        } catch {
          btn.textContent = "Copy failed";
        }
      });
      apply();
    })();
  </script>
</Base>
