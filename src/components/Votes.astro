---
// Vote display + upvote button. Static-side island.
//
// - Fetches /api/votes.json on load to display current count
// - When PUBLIC_API_BASE is set (Phase 4), POSTs to <apiBase>/upvote with a
//   Turnstile token. Until then, the button shows a Phase-4 message on click.
// - The hidden #vote-turnstile input gets filled by the same onTurnstileToken
//   callback used on /submit; sitekey embedding is conditional.

interface Props {
  entityId: string;
  /** Human-readable name for screen-reader labels; falls back to the id. */
  entityName?: string;
}
const { entityId, entityName } = Astro.props;
const apiBase = import.meta.env.PUBLIC_API_BASE ?? "";
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITEKEY ?? "";
---
<div class="votes" data-entity={entityId}>
  <button class="vote-btn" type="button" disabled aria-label={`Upvote ${entityName ?? entityId}`}>
    <span class="arrow" aria-hidden="true">▲</span>
    <span class="count" aria-live="polite">—</span>
  </button>
  <span class="status muted">votes</span>
</div>

{turnstileSiteKey && apiBase ? (
  <>
    <div class="cf-turnstile vote-turnstile" data-sitekey={turnstileSiteKey} data-callback="onVoteTurnstileToken" data-size="compact"></div>
    <input type="hidden" id={`vote-turnstile-${entityId}`} value="" />
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  </>
) : null}

<style>
  .votes { display: inline-flex; align-items: center; gap: 0.5rem; margin: 0.6rem 0; }
  .vote-btn { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.35rem 0.7rem; background: #f6f6f6; border: 1px solid #ddd; border-radius: 4px; cursor: pointer; font: inherit; font-size: 0.92rem; }
  .vote-btn:hover:not(:disabled) { background: #e8efff; border-color: #1a4cff; }
  .vote-btn:disabled { cursor: default; opacity: 0.7; }
  .vote-btn .arrow { color: #1a4cff; font-size: 0.85rem; }
  .vote-btn .count { font-variant-numeric: tabular-nums; font-weight: 600; }
  .status { font-size: 0.85rem; color: #666; }
  .vote-turnstile { display: inline-block; margin-left: 0.6rem; vertical-align: middle; }
</style>

<script is:inline define:vars={{ entityId, apiBase }}>
  (() => {
    const root = document.querySelector(`.votes[data-entity="${CSS.escape(entityId)}"]`);
    if (!root) return;
    const btn = root.querySelector(".vote-btn");
    const countEl = root.querySelector(".count");
    const status = root.querySelector(".status");

    // Vote-token plumbing — global because Turnstile callbacks are global.
    window.__voteTurnstileHandlers ||= {};
    window.__voteTurnstileHandlers[entityId] = (token) => {
      const el = document.getElementById("vote-turnstile-" + entityId);
      if (el) el.value = token;
    };
    window.onVoteTurnstileToken ||= (token) => {
      Object.values(window.__voteTurnstileHandlers || {}).forEach((handler) => handler(token));
    };

    const votesUrl = apiBase ? `${apiBase}/votes` : "/api/votes.json";
    fetch(votesUrl).then((r) => r.json()).then((d) => {
      const n = (d.counts && d.counts[entityId]) || 0;
      countEl.textContent = String(n);
      // Enable the button only when the live Worker is wired (apiBase set).
      if (apiBase) {
        btn.disabled = false;
        btn.title = "Upvote this entity";
      } else {
        btn.title = "Voting goes live in Phase 4 — see /about";
      }
    }).catch(() => { countEl.textContent = "—"; });

    btn.addEventListener("click", async () => {
      if (!apiBase) {
        status.textContent = "Phase 4 only";
        return;
      }
      btn.disabled = true;
      status.textContent = "submitting…";
      const turnstile = (document.getElementById("vote-turnstile-" + entityId) || {}).value;
      try {
        const res = await fetch(`${apiBase}/upvote`, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ entity: entityId, turnstile }),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && typeof data.count === "number") {
          countEl.textContent = String(data.count);
          status.textContent = "voted";
        } else {
          status.textContent = data.error || data.message || `error ${res.status}`;
          btn.disabled = false;
        }
      } catch (err) {
        status.textContent = "network error";
        btn.disabled = false;
      }
    });
  })();
</script>
