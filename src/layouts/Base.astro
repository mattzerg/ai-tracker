---
import { dedupedEventSummary, entityById, eventSlug, loadEvents } from "../lib/data.ts";
import { BUILD_TIME } from "../lib/build-info.ts";

interface Props {
  title: string;
  description?: string;
  ogImage?: string; // path or absolute URL
  ogType?: "website" | "article";
  canonical?: string; // absolute URL of this page
  hideLatestBanner?: boolean; // suppress the site-wide latest-event banner (e.g. on the event-self page)
}
const { title, description, ogImage, ogType = "website", canonical, hideLatestBanner = false } = Astro.props;
if (!Astro.site) throw new Error("Astro.site must be configured for canonical and social URLs.");
const siteUrl = Astro.site.toString().replace(/\/$/, "");
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
const resolvedImage = ogImage ?? "/og/default.png";
function absoluteAssetUrl(value: string): string {
  if (/^https?:\/\//.test(value)) return value;
  if (value.startsWith("//")) return `https:${value}`;
  if (/^(data|blob):/.test(value)) return value;
  return new URL(value, siteUrl).toString();
}
const absImage = absoluteAssetUrl(resolvedImage);

// Latest-event banner. Newest event surfaces with relative-age label so every
// page reminds visitors the data is live.
const latest = loadEvents()[0] ?? null;
const latestEntity = latest ? entityById(latest.entity) : null;
if (latest && !latestEntity) console.warn(`latest event references unknown entity: ${latest.entity}`);
const latestPath = latest ? `/events/${eventSlug(latest)}` : null;
const latestName = latestEntity?.name ?? latest?.entity ?? "";
function relativeAge(dateStr: string): string {
  const days = Math.floor((Date.now() - new Date(dateStr + "T12:00:00Z").getTime()) / 86400000);
  if (days <= 0) return "today";
  if (days === 1) return "1d ago";
  if (days < 30) return `${days}d ago`;
  if (days < 365) return `${Math.floor(days / 30)}mo ago`;
  return `${Math.floor(days / 365)}y ago`;
}
const latestAge = latest ? relativeAge(latest.date) : "";
const buildTime = BUILD_TIME;
const currentPath = Astro.url.pathname;
const navLinks = [
  { href: "/models", label: "Models" },
  { href: "/tools", label: "Tools" },
  { href: "/repos", label: "Repos" },
  { href: "/changes", label: "Changes" },
  { href: "/leaderboards", label: "Leaderboards" },
  { href: "/explorer", label: "Explorer" },
  { href: "/concord", label: "Concord" },
  { href: "/guides", label: "Guides" },
  { href: "/picker", label: "Picker" },
  { href: "/compare", label: "Compare" },
  { href: "/timeline", label: "Timeline" },
  { href: "/search", label: "Search" },
];
const actionLinks = [
  { href: "/submit", label: "Submit", primary: true },
  { href: "/about", label: "About", primary: false },
];
const noindexPreview = process.env.CF_PAGES === "1" && !process.env.SITE_URL;
function activeFor(href: string): boolean {
  return currentPath === href || currentPath.startsWith(`${href}/`);
}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    {description ? <meta name="description" content={description} /> : null}
    {canonicalUrl ? <link rel="canonical" href={canonicalUrl} /> : null}
    {noindexPreview ? <meta name="robots" content="noindex, nofollow" /> : null}

    <meta property="og:title" content={title} />
    {description ? <meta property="og:description" content={description} /> : null}
    <meta property="og:type" content={ogType} />
    {canonicalUrl ? <meta property="og:url" content={canonicalUrl} /> : null}
    {absImage ? <meta property="og:image" content={absImage} /> : null}
    <meta property="og:site_name" content="ai-tracker" />

    <meta name="twitter:card" content={absImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    {description ? <meta name="twitter:description" content={description} /> : null}
    {absImage ? <meta name="twitter:image" content={absImage} /> : null}

    <link rel="alternate" type="application/rss+xml" title="ai-tracker — every event (RSS)" href="/feed.xml" />
    <link rel="alternate" type="application/atom+xml" title="ai-tracker — every event (Atom)" href="/atom.xml" />
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav" aria-label="Primary">
        <a href="/" class="brand" aria-label="ai-tracker home">
          <span class="brand-mark" aria-hidden="true">ai</span>
          <span class="brand-text">ai-tracker</span>
        </a>
        <div class="nav-links">
          {navLinks.map((link) => (
            <a href={link.href} class:list={[activeFor(link.href) ? "active" : null]} aria-current={activeFor(link.href) ? "page" : undefined}>{link.label}</a>
          ))}
        </div>
        <div class="nav-actions">
          {actionLinks.map((link) => (
            <a href={link.href} class:list={[activeFor(link.href) ? "active" : null, link.primary ? "primary-action" : null]} aria-current={activeFor(link.href) ? "page" : undefined}>{link.label}</a>
          ))}
        </div>
      </nav>
    </header>
    {latest && latestPath && !hideLatestBanner ? (
      <aside class="latest-bar" aria-label="Latest tracked change">
        <span class="latest-label">Latest change</span>
        <a href={latestPath} class="latest-link">
          <strong>{latest.type.replaceAll("_", " ")}</strong>
          <span>{latestName}: {dedupedEventSummary(latest.summary, latestName)}</span>
        </a>
        <span class="latest-age">{latestAge}</span>
      </aside>
    ) : null}
    <div class="beta-bar">
      <strong>Public beta.</strong>
      <span>Coverage is source-backed and intentionally scoped. Rankings are metadata views, not universal quality claims.</span>
      <a href="/about#beta">Read the data policy</a>
    </div>
    <main>
      <slot />
    </main>
    <footer>
      <p>Public data. <a href="/providers">Providers</a> · <a href="/categories">Categories</a> · <a href="/picker">Picker</a> · <a href="/compare">Compare</a> · <a href="/timeline">Timeline</a> · <a href="/llms.txt" data-agent-endpoint="llms.txt">/llms.txt</a> · <a href="/dump/all.json" data-agent-endpoint="dump">/dump/all.json</a> · <a href="/feed.xml" data-agent-endpoint="rss">RSS</a> · <a href="/atom.xml" data-agent-endpoint="atom">Atom</a></p>
      <p class="build-time">Built {buildTime} UTC.</p>
    </footer>
    <style is:global>
      :root {
        font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
        line-height: 1.5;
        color: #18202f;
        background: #f6f7f9;
        --bg: #f6f7f9;
        --surface: #ffffff;
        --surface-soft: #f0f3f7;
        --text: #18202f;
        --muted: #687386;
        --faint: #dfe4ec;
        --line: #d8dee8;
        --accent: #0f6b5f;
        --accent-strong: #0b4f47;
        --accent-soft: #dff3ee;
        --blue: #2859d8;
        --shadow: 0 16px 40px rgba(24, 32, 47, 0.08);
      }
      * { box-sizing: border-box; }
      body { margin: 0; min-width: 320px; }
      main { max-width: 1180px; margin: 0 auto; padding: 2rem 1.5rem 3rem; }
      .site-header { position: sticky; top: 0; z-index: 20; background: rgba(255,255,255,0.92); border-bottom: 1px solid var(--line); backdrop-filter: blur(12px); }
      .site-nav { min-height: 64px; display: flex; align-items: center; gap: 1.25rem; max-width: 1180px; margin: 0 auto; padding: 0 1.5rem; }
      .site-header a { text-decoration: none; color: inherit; }
      .brand { display: inline-flex; align-items: center; gap: 0.65rem; font-weight: 750; letter-spacing: 0; white-space: nowrap; }
      .brand-mark { display: grid; place-items: center; width: 32px; height: 32px; border-radius: 7px; background: var(--accent); color: #fff; font-size: 0.8rem; line-height: 1; }
      .brand-text { font-size: 1rem; }
      .nav-links, .nav-actions { display: flex; align-items: center; gap: 0.25rem; flex-wrap: wrap; }
      .nav-links { flex: 1; }
      .nav-links a, .nav-actions a { color: var(--muted); font-size: 0.92rem; padding: 0.42rem 0.62rem; border-radius: 6px; }
      .nav-links a:hover, .nav-actions a:hover { color: var(--text); background: var(--surface-soft); }
      .nav-links a.active, .nav-actions a.active { color: var(--text); background: var(--surface-soft); font-weight: 700; }
      .nav-actions a.primary-action { color: var(--accent-strong); background: var(--accent-soft); font-weight: 650; }
      .nav-actions a.primary-action.active { background: #ccebe4; }
      .latest-bar { max-width: 1180px; margin: 0 auto; padding: 0.7rem 1.5rem; display: flex; gap: 0.75rem; align-items: center; font-size: 0.9rem; color: var(--muted); border-bottom: 1px solid var(--line); }
      .latest-label { color: var(--accent-strong); background: var(--accent-soft); border: 1px solid #bfe5dd; padding: 0.2rem 0.55rem; border-radius: 999px; font-weight: 700; font-size: 0.72rem; text-transform: uppercase; white-space: nowrap; }
      .latest-link { text-decoration: none; color: var(--text); display: flex; gap: 0.45rem; align-items: baseline; flex: 1; min-width: 0; overflow: hidden; }
      .latest-link span { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .latest-link:hover { color: var(--accent-strong); }
      .latest-link strong { color: var(--accent-strong); white-space: nowrap; }
      .latest-age { color: #525d72; font-variant-numeric: tabular-nums; white-space: nowrap; }
      .beta-bar { max-width: 1180px; margin: 0 auto; padding: 0.62rem 1.5rem; display: flex; gap: 0.65rem; align-items: center; color: #4f5a6d; font-size: 0.88rem; border-bottom: 1px solid var(--line); }
      .beta-bar strong { color: var(--text); white-space: nowrap; }
      .beta-bar span { flex: 1; min-width: 0; }
      .beta-bar a { color: var(--accent-strong); font-weight: 700; white-space: nowrap; }
      footer { max-width: 1180px; margin: 1rem auto 0; padding: 1.25rem 1.5rem 2rem; border-top: 1px solid var(--line); color: var(--muted); font-size: 0.9rem; }
      footer p { margin: 0.3rem 0; }
      footer .build-time { color: #8791a2; font-size: 0.82rem; }
      a { color: var(--blue); text-decoration-thickness: 1px; text-underline-offset: 0.18em; }
      h1, h2, h3 { line-height: 1.12; letter-spacing: 0; color: var(--text); }
      h1 { font-size: clamp(2.15rem, 4.6vw, 3.8rem); margin: 0; }
      h2 { font-size: clamp(1.45rem, 3vw, 2.15rem); margin: 0 0 1rem; }
      h3 { margin-top: 0; }
      p { color: var(--muted); }
      ul { padding-left: 1.25rem; }
      code { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; font-size: 0.92em; }
      .panel { background: var(--surface); border: 1px solid var(--line); border-radius: 8px; box-shadow: var(--shadow); }
      .eyebrow { margin: 0 0 0.85rem; color: var(--accent-strong); font-size: 0.78rem; font-weight: 750; text-transform: uppercase; letter-spacing: 0.06em; }
      .button-row { display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap; }
      .button { display: inline-flex; align-items: center; justify-content: center; min-height: 40px; padding: 0.55rem 0.85rem; border-radius: 7px; border: 1px solid var(--line); background: var(--surface); color: var(--text); text-decoration: none; font-weight: 650; }
      .button.primary { background: var(--text); color: #fff; border-color: var(--text); }
      .button:hover { border-color: #b8c2d1; background: #f8fafc; }
      .button.primary:hover { background: #2b3445; color: #fff; }
      table { max-width: 100%; }
      @media (max-width: 760px) {
        main { padding: 1.25rem 1rem 2rem; }
        .site-nav { min-height: auto; align-items: flex-start; flex-direction: column; gap: 0.7rem; padding: 0.85rem 1rem; }
        .nav-links, .nav-actions { width: 100%; overflow-x: auto; flex-wrap: nowrap; padding-bottom: 0.15rem; }
        .nav-links a, .nav-actions a { white-space: nowrap; }
        .latest-bar { padding: 0.7rem 1rem; align-items: flex-start; }
        .latest-link { display: block; }
        .latest-link span { display: block; white-space: normal; }
        .latest-age { display: none; }
        .beta-bar { padding: 0.62rem 1rem; align-items: flex-start; flex-direction: column; gap: 0.2rem; }
        .beta-bar a { white-space: normal; }
      }
    </style>
    <script>
      // Privacy-first, agent-aware analytics. No-op unless PUBLIC_ANALYTICS_ENDPOINT
      // is set; honors DNT + an opt-out flag. See src/lib/analytics.ts.
      import { initAnalytics } from "../lib/analytics-client.ts";
      initAnalytics();
    </script>
  </body>
</html>
