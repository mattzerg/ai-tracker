---
import { entityById, eventSlug, loadEvents } from "../lib/data.ts";

interface Props {
  title: string;
  description?: string;
  ogImage?: string; // path or absolute URL
  ogType?: "website" | "article";
  canonical?: string; // absolute URL of this page
  hideLatestBanner?: boolean; // suppress the site-wide latest-event banner (e.g. on the event-self page)
}
const { title, description, ogImage, ogType = "website", canonical, hideLatestBanner = false } = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const canonicalUrl = canonical ?? (siteUrl + Astro.url.pathname);
const resolvedImage = ogImage ?? "/og/default.png";
const absImage = resolvedImage.startsWith("http") ? resolvedImage : siteUrl + resolvedImage;

// Latest-event banner. Newest event surfaces with relative-age label so every
// page reminds visitors the data is live.
const latest = loadEvents()[0] ?? null;
const latestEntity = latest ? entityById(latest.entity) : null;
const latestPath = latest ? `/events/${eventSlug(latest)}` : null;
const latestName = latestEntity?.name ?? latest?.entity ?? "";
function relativeAge(dateStr: string): string {
  const days = Math.floor((Date.now() - new Date(dateStr + "T12:00:00Z").getTime()) / 86400000);
  if (days <= 0) return "today";
  if (days === 1) return "1d ago";
  if (days < 30) return `${days}d ago`;
  if (days < 365) return `${Math.floor(days / 30)}mo ago`;
  return `${Math.floor(days / 365)}y ago`;
}
const latestAge = latest ? relativeAge(latest.date) : "";
const buildTime = new Date().toISOString().slice(0, 16).replace("T", " ");
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    {description ? <meta name="description" content={description} /> : null}
    {canonicalUrl ? <link rel="canonical" href={canonicalUrl} /> : null}

    <meta property="og:title" content={title} />
    {description ? <meta property="og:description" content={description} /> : null}
    <meta property="og:type" content={ogType} />
    {canonicalUrl ? <meta property="og:url" content={canonicalUrl} /> : null}
    {absImage ? <meta property="og:image" content={absImage} /> : null}
    <meta property="og:site_name" content="ai-tracker" />

    <meta name="twitter:card" content={absImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    {description ? <meta name="twitter:description" content={description} /> : null}
    {absImage ? <meta name="twitter:image" content={absImage} /> : null}

    <link rel="alternate" type="application/rss+xml" title="ai-tracker — every event (RSS)" href="/feed.xml" />
    <link rel="alternate" type="application/atom+xml" title="ai-tracker — every event (Atom)" href="/atom.xml" />
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <header>
      <nav>
        <a href="/"><strong>ai-tracker</strong></a>
        <a href="/models">Models</a>
        <a href="/tools">Tools</a>
        <a href="/providers">Providers</a>
        <a href="/categories">Categories</a>
        <a href="/compare">Compare</a>
        <a href="/news">News</a>
        <a href="/timeline">Timeline</a>
        <a href="/changes">Changes</a>
        <a href="/search">Search</a>
        <a href="/submit">Submit</a>
        <a href="/about">About</a>
      </nav>
    </header>
    {latest && latestPath && !hideLatestBanner ? (
      <div class="latest-bar">
        <span class="latest-label">Latest</span>
        <a href={latestPath} class="latest-link">
          <strong>{latest.type}</strong> · {latestName} — {latest.summary}
        </a>
        <span class="latest-age">{latestAge}</span>
      </div>
    ) : null}
    <main>
      <slot />
    </main>
    <footer>
      <p>Public data. <a href="/llms.txt">/llms.txt</a> · <a href="/dump/all.json">/dump/all.json</a> · <a href="/feed.xml">RSS</a> · <a href="/atom.xml">Atom</a></p>
      <p class="build-time">Data refreshed {buildTime} UTC.</p>
    </footer>
    <style is:global>
      :root {
        font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
        line-height: 1.5;
        color: #111;
        background: #fff;
      }
      body { margin: 0; }
      main { max-width: 880px; margin: 0 auto; padding: 1.5rem; }
      header { padding: 1rem 1.5rem; border-bottom: 1px solid #eee; }
      header nav { display: flex; gap: 1rem; max-width: 880px; margin: 0 auto; flex-wrap: wrap; }
      header a { text-decoration: none; color: inherit; }
      .latest-bar { max-width: 880px; margin: 0 auto; padding: 0.45rem 1.5rem; display: flex; gap: 0.6rem; align-items: baseline; font-size: 0.85rem; color: #444; border-bottom: 1px solid #f0f0f0; flex-wrap: wrap; }
      .latest-label { background: #1a4cff; color: #fff; padding: 0.05rem 0.5rem; border-radius: 999px; font-weight: 600; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px; }
      .latest-link { text-decoration: none; color: inherit; flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .latest-link:hover { color: #1a4cff; }
      .latest-link strong { color: #1a4cff; }
      .latest-age { color: #888; font-variant-numeric: tabular-nums; }
      footer { max-width: 880px; margin: 2rem auto; padding: 1rem 1.5rem; border-top: 1px solid #eee; color: #666; font-size: 0.9rem; }
      footer p { margin: 0.3rem 0; }
      footer .build-time { color: #999; font-size: 0.8rem; }
      a { color: #1a4cff; }
      h1, h2, h3 { line-height: 1.2; }
      ul { padding-left: 1.25rem; }
    </style>
  </body>
</html>
